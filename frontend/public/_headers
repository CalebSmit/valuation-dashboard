# Cloudflare Pages cache headers
# Hashed JS/CSS bundles are safe to cache indefinitely (Vite appends content hash to filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point must never be cached so deploys reach users immediately
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# SVG icons
/*.svg
  Cache-Control: public, max-age=86400

# Favicon
/favicon.svg
  Cache-Control: public, max-age=86400
