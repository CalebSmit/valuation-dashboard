# ── Backend (FastAPI) ────────────────────────────────────────────────────────
VALUATION_DASHBOARD_BACKEND_HOST=127.0.0.1
VALUATION_DASHBOARD_BACKEND_PORT=8000

# Comma-separated list of allowed frontend origins (for CORS).
# Add your Cloudflare Pages URL here when deploying split.
VALUATION_DASHBOARD_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional backend-owned provider keys. If set, the dashboard can run without browser-stored keys.
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# ── Frontend (Vite build) ─────────────────────────────────────────────────────
# Leave empty for local dev (Vite proxies /api to localhost:8000).
# For split deployment (frontend on Cloudflare Pages, backend on Fly.io/Render/etc.),
# set this to your backend's public URL, e.g.:
#   VITE_API_BASE_URL=https://your-api.fly.dev
# Also set VALUATION_DASHBOARD_FRONTEND_PORT if running dev server on a non-default port.
VITE_API_BASE_URL=
VALUATION_DASHBOARD_FRONTEND_PORT=5173
